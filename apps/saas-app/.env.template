# Environment variables for Cyoda SaaS App
# Copy this file to .env and update the values.
#
# ⚠️  SECURITY: every variable prefixed with VITE_ is INLINED INTO THE
#     CLIENT-SIDE JAVASCRIPT BUNDLE by Vite at build time and shipped to
#     every browser that loads the app. Anything you put after a `VITE_`
#     name is therefore PUBLIC — visible in DevTools, in the bundle on
#     disk, and to any user of the app.
#
#     Never put a real secret (API key, password, signing key, refresh
#     token, ...) behind a VITE_ prefix. If you need a secret, it must be
#     held by a backend or by the dev-server proxy at runtime, not by
#     anything in this file.
#
#     SPA-style identifiers like an Auth0 client ID, audience, or
#     organization ID are NOT secrets — Auth0 designs them to be public
#     and the SPA login flow's security comes from the Allowed Callback
#     URLs and PKCE, not from hiding the client ID. Putting them here
#     is fine.

# ============================================================================
# API Configuration
# ============================================================================

# Main API Base URL
# For development with Vite proxy: Leave empty or use "/"
# For production build: Use full URL like https://cyoda-develop.kube.cyoda.org/api
# Development (with Vite proxy):
VITE_APP_API_BASE=

# Processing API Base URL
# For development with Vite proxy: Leave empty or use "/"
# For production build: Use full URL like https://cyoda-develop.kube.cyoda.org/api/processing
# Development (with Vite proxy):
VITE_APP_API_BASE_PROCESSING=

# Base URL for the application
VITE_APP_BASE_URL=https://cyoda-develop.kube.cyoda.org/

# ============================================================================
# Grafana Configuration
# ============================================================================
#
# ⚠️  DANGER: VITE_APP_GRAFANA_API_KEY is bundled into the client-side
#     JavaScript and shipped to every user. DO NOT put a real Grafana
#     API key here — anyone who loads the app will be able to read it
#     out of the bundle and use it. Leave the placeholder, or proxy
#     Grafana calls through a backend that holds the key server-side.

VITE_APP_GRAFANA_API_URL=https://grafana.cyoda.com/api
VITE_APP_GRAFANA_API_KEY=<placeholder-do-not-put-real-key-here>
VITE_APP_GRAFANA_SERVER_SOURCE_ID=1

# ============================================================================
# Auth0 Configuration
# ============================================================================
#
# These four values are NOT secrets — Auth0 SPA client IDs, audiences and
# organization IDs are designed to be public (security comes from the
# Allowed Callback URLs and PKCE, not from hiding the IDs). However, this
# template uses placeholders so it stays a template: real values live in
# your gitignored apps/saas-app/.env, never here.
#
# Get the actual values from your Cyoda Auth0 tenant administrator, or
# from the Auth0 dashboard for the SaaS App application.

VITE_APP_AUTH0_DOMAIN=auth.cyoda.net
VITE_APP_AUTH0_CLIENT_ID=<your-auth0-spa-client-id>
VITE_APP_AUTH0_AUDIENCE=https://cloud.cyoda.com/api
VITE_APP_AUTH0_ORGANIZATION=<your-auth0-org-id>           # e.g. org_xxxxxxxxxxxxxxxx

# ============================================================================
# Debug
# ============================================================================

VITE_APP_DEBUG=true

# ============================================================================
# Feature Flags
# ============================================================================

VITE_FEATURE_FLAG_USE_MODELS_INFO=true
VITE_FEATURE_FLAG_TRINO_SQL_SCHEMA=true
# VITE_FEATURE_FLAG_TASKS=false
VITE_FEATURE_FLAG_IS_CYODA_CLOUD=true
