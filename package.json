{
  "name": "cyoda-saas-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Cyoda SaaS Platform - React-based monorepo",
  "author": "Cyoda",
  "license": "PRIVATE",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter @cyoda/saas-app dev",
    "dev:all": "pnpm -r --parallel --if-present run dev",
    "dev:saas": "pnpm --filter @cyoda/saas-app dev",
    "build": "pnpm -r --if-present run build",
    "build:saas": "pnpm --filter ...@cyoda/saas-app run build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "lint": "pnpm -r --if-present run lint",
    "type-check": "pnpm -r --if-present run type-check",
    "clean": "pnpm -r --if-present run clean && rm -rf node_modules",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@playwright/test",
      "browser-tabs-lock",
      "core-js",
      "core-js-pure",
      "cypress",
      "esbuild",
      "msw",
      "playwright",
      "puppeteer"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.10.7",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "buffer": "^6.0.3",
    "jsdom": "^27.0.0",
    "playwright": "^1.56.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=4.6.0"
  },
  "overrides": {
    "dompurify": "^3.2.4"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.8.0",
    "cytoscape": "^3.33.1",
    "event-source-polyfill": "^1.0.31",
    "file-saver": "^2.0.5",
    "html-entities": "^2.6.0",
    "js-beautify": "^1.15.4",
    "mark.js": "^8.11.1",
    "monaco-editor": "^0.54.0",
    "prismjs": "^1.30.0",
    "uuid": "^13.0.0"
  }
}
