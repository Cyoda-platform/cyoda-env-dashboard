# pnpm configuration
#
# node-linker=hoisted produces a flat node_modules layout (like npm/yarn
# classic) instead of pnpm's strict symlink farm. We use this because the
# codebase has historically relied on hoisted dependencies — several
# packages import modules they don't declare in their own package.json
# (phantom dependencies). Flipping back to node-linker=isolated will
# surface every such case at build time. That cleanup is tracked as a
# follow-up to the pnpm migration; do it package by package.
node-linker=hoisted

# The user's global ~/.npmrc routes the @cyoda scope to a private Nexus
# registry. For this monorepo we always want @cyoda/* to resolve from the
# local workspace, never from Nexus. These two settings make pnpm prefer
# workspace packages even when the version is specified literally
# (e.g. "1.0.0") instead of "workspace:*".
link-workspace-packages=deep
prefer-workspace-packages=true

auto-install-peers=true
strict-peer-dependencies=false
